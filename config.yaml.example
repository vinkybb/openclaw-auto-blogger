# 博客流水线示例配置
# 复制此文件为 config.yaml 并填入你的配置

# RSS源配置
rss:
  sources:
    # 示例 RSS 源
    - name: "奇客Solidot"
      url: "https://www.solidot.org/index.rss"
      enabled: true
    - name: "36氪"
      url: "https://36kr.com/feed"
      enabled: true
    - name: "少数派"
      url: "https://sspai.com/feed"
      enabled: false
  # 抓取间隔 (秒)
  fetch_interval: 3600

# OpenClaw 配置
# 用于 AI 内容生成 (摘要、扩写)
openclaw:
  # OpenClaw Gateway URL
  # 如果在同一台机器上运行，使用 localhost
  base_url: "http://localhost:3000"
  # 请求超时时间 (秒)
  timeout: 300
  # 指定模型 (可选，留空使用系统默认)
  model: null

# 内容生成设置
content:
  # 摘要长度
  summary_length: 200
  # 文章目标字数
  article_length: 1500
  # 输出语言
  language: "zh-CN"
  # 是否在文末包含原文链接
  include_source: true
  # 写作风格
  style: "深度分析"

# 配图生成 (可选)
image:
  enabled: false
  # 提供商: unsplash / placeholder / none
  provider: "unsplash"
  # Unsplash 访问密钥 (可选，不填使用公开 API)
  access_key: null

# 发布设置
publish:
  # 本地文件输出
  local:
    enabled: true
    # 输出目录
    content_dir: "./output/posts"
  
  # GitHub Pages 发布
  github:
    enabled: false
    repo: "your-username/your-blog"
    branch: "main"
    # GitHub Personal Access Token
    token: null
    commit_message: "Auto publish: {title}"
  
  # WordPress 发布
  wordpress:
    enabled: false
    url: "https://your-blog.com/xmlrpc.php"
    username: null
    password: null

# 定时任务设置
scheduler:
  enabled: false
  # 运行时间表 (cron 格式)
  schedule: "0 8,20 * * *"  # 每天 8:00 和 20:00 运行
  timezone: "Asia/Shanghai"