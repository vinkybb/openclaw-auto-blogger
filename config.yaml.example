# =============================================================================
# 博客流水线示例配置 — 复制为 config.yaml 后按需填写
# =============================================================================
#
# 运行：python app.py
# 需要：运行中的 OpenClaw Gateway + 环境变量 OPENCLAW_GATEWAY_TOKEN
# 摘要/扩写：Gateway tools/invoke → sessions_spawn
# 文档: https://docs.openclaw.ai/gateway/tools-invoke-http-api
#
# =============================================================================

rss:
  sources:
    # ============ 测试可用的RSS源 (baoyu-reader) ============
    - name: "TechCrunch"
      url: "https://techcrunch.com/feed/"
      enabled: true
    - name: "LessWrong"
      url: "https://www.lesswrong.com/feed.xml"
      enabled: true
    - name: "Alignment Forum"
      url: "https://www.alignmentforum.org/feed.xml"
      enabled: true
    - name: "阮一峰博客"
      url: "https://www.ruanyifeng.com/blog/atom.xml"
      enabled: true
    - name: "AWS ML Blog"
      url: "https://aws.amazon.com/blogs/machine-learning/feed/"
      enabled: true
    - name: "HackerNews AI"
      url: "https://hnrss.org/frontpage?q=ai+OR+llm+OR+gpt+OR+machine+learning"
      enabled: true
    - name: "HackerNews Best"
      url: "https://hnrss.org/best"
      enabled: true
    - name: "Azure Blog"
      url: "https://azure.microsoft.com/en-us/blog/feed/"
      enabled: true

openclaw:
  gateway_url: "http://127.0.0.1:18789"
  gateway_token: null
  base_url: "http://127.0.0.1:18789"
  timeout: 300
  model: null

content:
  summary_length: 200
  article_length: 1500
  language: "zh-CN"
  include_source: true
  style: "深度分析"

publish:
  local:
    enabled: true
    content_dir: "./output/posts"

  github:
    enabled: false
    repo: "your-username/your-blog"
    branch: "main"
    token: null
    commit_message: "Auto publish: {title}"

  # WordPress REST API：使用「应用密码」基本认证
  # url 可为站点根 https://your-blog.com、或 .../wp-json、或旧版 xmlrpc.php（将自动换为 REST）
  wordpress:
    enabled: false
    url: "https://your-blog.com"
    username: null
    password: null
